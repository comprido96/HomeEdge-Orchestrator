FROM rust:1.90-bookworm AS builder
WORKDIR /app

COPY . .
RUN cargo build --release -p homeedge-agent

FROM debian:bookworm-slim
RUN apt-get update \
    && apt-get install -y --no-install-recommends ca-certificates \
    && rm -rf /var/lib/apt/lists/*

COPY --from=builder /app/target/release/homeedge-agent /usr/local/bin/homeedge-agent

CMD ["/usr/local/bin/homeedge-agent"]
