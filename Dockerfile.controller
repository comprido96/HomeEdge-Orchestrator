FROM rust:1.90-bookworm AS builder
WORKDIR /app

COPY . .
RUN cargo build --release -p homeedge-controller

FROM debian:bookworm-slim
RUN apt-get update \
    && apt-get install -y --no-install-recommends ca-certificates \
    && rm -rf /var/lib/apt/lists/*

COPY --from=builder /app/target/release/homeedge-controller /usr/local/bin/homeedge-controller

EXPOSE 8080
CMD ["/usr/local/bin/homeedge-controller"]
